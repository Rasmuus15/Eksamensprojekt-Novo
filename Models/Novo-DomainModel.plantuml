@startuml
hide circle
hide empty members

skinparam padding 10
skinparam nodesep 100
skinparam ranksep 100

Projektkoordinator "1" ---right--- "0..*" Projekt
Fase "8" ---left--- "1" Projekt
Fase "1..*" ---right--- "1..*" Ressource

'Konceptuelle klasser
Class Projektkoordinator
{
    initialer
}

Class Ressource
{
    initialer
    mail
    rolle
    antalTimer
    ledighed
}

Class Fase
{
    faseNavn
    startDato
    slutDato
}

Class Projekt
{
    projektNavn
    kompleksitet
    startDato
    slutDato
}




@enduml