<UserControl x:Class="NovoForecastingSystem.Views.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NovoForecastingSystem.Views.Charts.GanttChart"
             xmlns:templates="clr-namespace:NovoForecastingSystem.Views.Templates"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:charts="clr-namespace:NovoForecastingSystem.Views.Charts.GanttChart"
             mc:Ignorable="d" 
             d:DesignHeight="1650" d:DesignWidth="800" Background="#f9fafb">

    <Grid>
        <!-- Window rows for back to project and the rest of the window-->
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="← Back to projects" HorizontalAlignment="Left" Width="120" Background="Transparent" Foreground="#4a5565" BorderThickness="0" Cursor="Hand" Command="{Binding NavigateToDashboardViewCommand}"/>

        <!-- Rows for the rest of the window besides the back to project button-->
        <ScrollViewer Grid.Row="1">
            <Border Grid.Row="1" CornerRadius="6" Background="White" Padding="12" Margin="15" BorderThickness="1" BorderBrush="Gray">
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="140"/>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="500"/>
                        <RowDefinition Height="600"/>
                    </Grid.RowDefinitions>

                    <!-- Project title and buttons-->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="113"/>
                            <ColumnDefinition Width="113"/>
                            <ColumnDefinition Width="125"/>
                        </Grid.ColumnDefinitions>


                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="{Binding CurrentProject.ProjectName}" FontSize="20" Margin="10,5,0,0" FontWeight="Bold"/>
                            <TextBlock Margin="12,0,0,0" Foreground="Gray">
                                <Run Text="Phase "/>
                                <Run Text="{Binding CurrentProject.Phase.DisplayPhaseStage, Mode=OneWay}"/>
                                <Run Text=" ["/>
                                <Run Text="{Binding CurrentProject.Phase.phaseStage, Mode=OneWay}"/>
                                <Run Text="]"/>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1" Margin="5,5,5,5" Content="🗑 Delete Project" Background="#E7000B" Foreground="White" Cursor="Hand" Command="{Binding DeleteProjectCommand}" CommandParameter="{Binding}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="2" Margin="5,5,5,5" Content="📝 Edit Project" Background="#4a5565" Foreground="White" Cursor="Hand" Click="EditProject_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="3" Margin="5,5,5,5" Content="+ Add Resources" Background="#FF0056FF" Foreground="White" Cursor="Hand" Click="AddResource_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>


                    <Grid Grid.Row="1">
                        <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                            <ItemsControl x:Name="ResourcesNeeded">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <templates:RoleRequirementBox Margin="10,0,0,0" Tag="#2b7fff" Foreground="#2b7fff"/>
                                <templates:RoleRequirementBox Margin="20,0,0,0" Tag="#00c950" Foreground="#00c950"/>
                                <templates:RoleRequirementBox Margin="20,0,0,0" Tag="#ad46ff" Foreground="#ad46ff"/>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">

                        <Border Width="282" Margin="0,0,0,0" Background="#f9fafb" CornerRadius="3" BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Complexity" Margin="20,20,0,0"/>
                                <TextBlock Grid.Row="1" Text="{Binding CurrentProject.ComplexityEnum}" Margin="20,0,0,30" FontWeight="Bold" FontSize="18"/>
                            </Grid>
                        </Border>

                        <Border Width="282" Margin="50,0,0,0" Background="#f9fafb" CornerRadius="3" BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Start Date" Margin="20,20,0,0"/>
                                <TextBlock Grid.Row="1" Text="{Binding CurrentProject.StartDate, StringFormat=dd-MM-yyyy}" Margin="20,0,0,30" FontWeight="Bold" FontSize="18"/>
                            </Grid>
                        </Border>

                        <Border Width="282" Margin="50,0,0,0" Background="#f9fafb" CornerRadius="3" BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Expected End Date" Margin="20,20,0,0"/>
                                <TextBlock Grid.Row="1" Text="{Binding CurrentProject.EndDate, StringFormat=dd-MM-yyyy}" Margin="20,0,0,30" FontWeight="Bold" FontSize="18"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Margin="20" Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Project Timeline" FontSize="25" FontWeight="Bold" Margin="20,0,0,0"/>

                        <Border Grid.Row="1">
                            <lvc:CartesianChart
                                Series="{Binding GanttVM.Series}"
                                YAxes="{Binding GanttVM.YAxes}"
                                XAxes="{Binding GanttVM.XAxes}"
                                LegendPosition="Hidden"
                                TooltipPosition="Hidden"/>
                        </Border>
                    </Grid>

                    <Grid Margin="20" Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="600"/>
                        </Grid.RowDefinitions>

                        <templates:FTEDemandByPhase_Role Grid.Row="1" Margin="0,10,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
