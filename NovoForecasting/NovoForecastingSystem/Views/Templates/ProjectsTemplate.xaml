<UserControl
    x:Class="NovoForecastingSystem.Views.Templates.ProjectsTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NovoForecastingSystem.Views.Templates"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:NovoForecastingSystem.Models"
    Width="250"
    Height="130"
    mc:Ignorable="d">
    <Border
        Background="White"
        BorderBrush="#f3f4f6"
        BorderThickness="2"
        CornerRadius="8">
        <StackPanel>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="59" />
                </Grid.ColumnDefinitions>
                <!--Title-->
                <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="10,10,0,0"
                    Text="{Binding ProjectName}"
                    FontWeight="Bold"/>
                <TextBlock
                    Grid.Row="1"
                    Margin="8,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="📋"
                    TextWrapping="Wrap"
                    FontSize="10"/>
                <TextBlock
                    Grid.Row="1"
                    Margin="22,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Phase"
                    TextWrapping="Wrap" />
                <!--Phase nr.-->
                <TextBlock 
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Text="{Binding}"
                    Foreground="Gray"
                    TextWrapping="Wrap" 
                    Margin="57,1,0,0" />
                <TextBlock
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="167"
                    Margin="10,19,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="#f3f4f6"
                    Text="_________________________________"
                    TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Text="Detailed Design" FontSize="8" Foreground="#94A3B8" Margin="23,19,3,49"/>

                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,37,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Start:"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,51,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="End:"
                    TextWrapping="Wrap" />
                <!--Start dato-->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="49"
                    Margin="10,40,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="{Binding StartDate}"
                    TextWrapping="Wrap" />
                <!--slut dato-->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="49"
                    Margin="10,55,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="{Binding EndDate}"
                    TextWrapping="Wrap" />
                <Border Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" Background="#DCFCE7" CornerRadius="4" Padding="8,4" Margin="8">
                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#166534" FontWeight="SemiBold" Height="16" VerticalAlignment="Center"/>
                </Border>
                <ProgressBar
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="227"
                    Height="10"
                    Margin="10,77,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Blue"
                    LargeChange="0"
                    Maximum="167"
                    Value="20">

                    <ProgressBar.Resources>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <!-- Baggrund -->
                                            <Border Background="#ddd" CornerRadius="5"/>

                                            <!-- Progress -->
                                            <Border Background="Blue" CornerRadius="5" Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value}" HorizontalAlignment="Left"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
