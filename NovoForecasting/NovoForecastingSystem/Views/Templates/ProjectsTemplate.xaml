<UserControl
    x:Class="NovoForecastingSystem.Views.Templates.ProjectsTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NovoForecastingSystem.Views.Templates"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:NovoForecastingSystem.Models"
    Width="250"
    Height="130"
    mc:Ignorable="d">
    <Border
        Background="White"
        BorderBrush="#f3f4f6"
        BorderThickness="2"
        CornerRadius="8">
        <StackPanel>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="59" />
                </Grid.ColumnDefinitions>
                <!--  Title  -->
                <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="10,10,0,0"
                    FontWeight="Bold"
                    Text="{Binding ProjectName}" />
                <TextBlock
                    Grid.Row="1"
                    Margin="8,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="10"
                    Foreground="Gray"
                    Text="📋"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Margin="22,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Phase"
                    TextWrapping="Wrap" />
                <!--  Phase nr.  -->
                <TextBlock
                    x:Name="PhaseStageNumberTxt"
                    Grid.Row="1"
                    Margin="57,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="{Binding Phase.DisplayPhaseStage, Mode=OneWay}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="167"
                    Margin="10,19,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="#f3f4f6"
                    Text="_________________________________"
                    TextWrapping="Wrap" />

                <TextBlock
                    x:Name="PhaseTxt"
                    Grid.Row="1"
                    Margin="23,19,3,49"
                    FontSize="8"
                    Foreground="#94A3B8"
                    Text="{Binding Phase.phaseStage}" />

                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,37,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Start:"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,51,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="End:"
                    TextWrapping="Wrap" />
                <!--  Start dato  -->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="49"
                    Margin="10,40,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="{Binding StartDate}"
                    TextWrapping="Wrap" />
                <!--  slut dato  -->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="49"
                    Margin="10,55,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="{Binding EndDate}"
                    TextWrapping="Wrap" />
                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="50"
                    Margin="0,8,0,8"
                    HorizontalAlignment="Left"
                    CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ComplexityEnum}" Value="Low">
                                    <Setter Property="Background" Value="#dbfce7" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ComplexityEnum}" Value="Medium">
                                    <Setter Property="Background" Value="#fef9c2" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ComplexityEnum}" Value="High">
                                    <Setter Property="Background" Value="#ffe2e2" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBlock
                        x:Name="ComplexityTxtBx"
                        Height="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Text="{Binding ComplexityEnum}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Transparent" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComplexityEnum}" Value="Low">
                                        <Setter Property="Foreground" Value="#108b43" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding ComplexityEnum}" Value="Medium">
                                        <Setter Property="Foreground" Value="#a96508" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding ComplexityEnum}" Value="High">
                                        <Setter Property="Foreground" Value="#c10007" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <ProgressBar
                    x:Name="Phase_ComboBox"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="227"
                    Height="10"
                    Margin="10,77,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Blue"
                    LargeChange="0"
                    Maximum="8"
                    Value="{Binding Phase.DisplayComboBox, Mode=OneWay}">

                    <ProgressBar.Resources>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <!--  Baggrund  -->
                                            <Border Background="#ddd" CornerRadius="5" />

                                            <!--  Progress  -->
                                            <Border
                                                Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value}"
                                                HorizontalAlignment="Left"
                                                Background="Blue"
                                                CornerRadius="5" />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
