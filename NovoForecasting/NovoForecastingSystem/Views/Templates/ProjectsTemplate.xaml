<UserControl
    x:Class="NovoForecastingSystem.Views.Templates.ProjectsTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NovoForecastingSystem.Views.Templates"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="189"
    Height="106"
    mc:Ignorable="d">

    <Border
        Background="White"
        BorderBrush="White"
        BorderThickness="2"
        CornerRadius="8">
        <StackPanel>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="59" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="10,10,0,0"
                    Text="Projekt" />
                <TextBlock
                    Grid.Row="1"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Phase"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="163"
                    Margin="22,10,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="__________________________"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,26,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="Start:"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Width="31"
                    Margin="10,42,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Gray"
                    Text="End:"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Margin="46,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Text="1 / 8"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="69"
                    Margin="10,30,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="01-01-2000"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="69"
                    Margin="10,46,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontSize="8"
                    Foreground="Black"
                    Text="01-01-2000"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Column="1"
                    Width="31"
                    Margin="28,5,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Green"
                    Text="Low"
                    TextWrapping="Wrap" />


                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,0,40">
                    <Border
                        Width="44"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        Background="#2b7fff"
                        CornerRadius="6" />
                </StackPanel>
                <ProgressBar
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Width="100"
                    Height="10"
                    Margin="42,58,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="Blue"
                    LargeChange="0"
                    Maximum="8"
                    Value="7" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
