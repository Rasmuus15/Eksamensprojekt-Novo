<Window
    x:Class="NovoForecastingSystem.Views.AddResourceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NovoForecastingSystem.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Add Resources"
    Width="380"
    Height="550"
    Background="White"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,25"
            FontSize="24"
            FontWeight="Bold"
            Foreground="#0F172A"
            Text="Add Resources" />

        <!--  Phase  -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock
                Margin="0,0,0,8"
                FontWeight="SemiBold"
                Foreground="#334155"
                Text="Phase:" />
            <ComboBox
                x:Name="Phase_ComboBox"
                Height="40"
                Padding="10,0"
                VerticalContentAlignment="Center" />
        </StackPanel>

        <!--  Role  -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock
                Margin="0,0,0,8"
                FontWeight="SemiBold"
                Foreground="#334155"
                Text="Role:" />
            <ComboBox
                x:Name="Role_ComboBox"
                Height="40"
                Padding="10,0"
                VerticalContentAlignment="Center"
                SelectionChanged="Role_ComboBox_SelectionChanged" />
        </StackPanel>

        <!--  Allocation Status  -->
        <Border
            Grid.Row="3"
            Margin="0,10,0,25"
            Padding="15"
            Background="#F8FAFC"
            BorderBrush="#E2E8F0"
            BorderThickness="1.5"
            CornerRadius="8">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="#334155"
                    Text="Allocation Status:" />
                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#16A34A"
                    Text="0 / 1" />
            </Grid>
        </Border>

        <!--  Email  -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock
                Margin="0,0,0,8"
                FontWeight="SemiBold"
                Foreground="#334155"
                Text="Email:" />
            <ComboBox
                x:Name="Email_ComboBox"
                Height="40"
                Padding="10,0"
                VerticalContentAlignment="Center" />
        </StackPanel>

        <!--  Buttons  -->
        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="Add_Button"
                Grid.Column="0"
                Height="44"
                Background="#2563EB"
                BorderThickness="0"
                Click="Add_Button_Click"
                Content="Add"
                Cursor="Hand"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button
                Grid.Column="2"
                Height="44"
                Background="#E2E8F0"
                BorderThickness="0"
                Click="Close_Button_Click"
                Content="Close"
                Cursor="Hand"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="#334155">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
